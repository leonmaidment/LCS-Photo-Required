# --- Server -----------------------------------------------------------------
PORT=4000
NODE_ENV=development

# --- Mock mode --------------------------------------------------------------
# When true, the backend simulates Monday.com and transcription locally so the
# app can be explored without real credentials. Set to false in production.
MOCK_MODE=true

# --- Monday.com -------------------------------------------------------------
# Personal API token (Monday > Profile > Developers > API). Required when
# MOCK_MODE=false.
MONDAY_API_TOKEN=

# Monday API version (string, e.g. 2024-10). Optional; defaults to latest stable.
MONDAY_API_VERSION=2024-10

# Master board where every site visit becomes a new item. Change this value
# (or the deployed env var) to point the app at a different board later.
SITE_VISITS_BOARD_ID=

# --- Transcription ----------------------------------------------------------
# TRANSCRIPTION_PROVIDER controls which transcription engine is used.
#
#   none   — Audio is uploaded but transcript stays "pending" forever.
#             Use when you have no transcription key and just want evidence upload.
#
#   mock   — Backend returns a realistic fake transcript instantly.
#             Safe for local development and demos — no API calls, no cost.
#             Switch back here at any time by setting TRANSCRIPTION_PROVIDER=mock.
#
#   openai — Calls the OpenAI audio transcription API (Whisper).
#             Requires OPENAI_API_KEY below.
#             Uses a paid API — check your usage at platform.openai.com.
#             Transcription quality is excellent for clear field recordings.
#
# Quick setup for live transcription:
#   1. Log in to platform.openai.com → API keys → Create new secret key.
#   2. Set OPENAI_API_KEY=sk-...  (keep this in backend .env only — never in the app).
#   3. Set TRANSCRIPTION_PROVIDER=openai.
#   4. Restart the backend (Ctrl-C then npm run dev).
#
# To switch back to mock at any time:
#   Set TRANSCRIPTION_PROVIDER=mock and restart — no other changes needed.
#
# TRANSCRIPTION_MODEL sets the OpenAI model (optional).
#   Default is whisper-1, which is stable and broadly supported.
#   To use a newer model (e.g. gpt-4o-transcribe) set it explicitly.
#   Leave blank to use the default.
#
TRANSCRIPTION_PROVIDER=mock
OPENAI_API_KEY=
TRANSCRIPTION_MODEL=

# --- Auth (lightweight gate for MVP) ----------------------------------------
# Shared bearer token the mobile app sends in the Authorization header.
# In a real deployment, replace with proper SSO/JWT.
APP_SHARED_SECRET=lcs-dev-secret

# ===========================================================================
# --- Make.com webhook bridge (PREFERRED — no Entra ID required) ------------
# ===========================================================================
#
# This is the recommended way to upload visit evidence to SharePoint.
# You do NOT need a Microsoft Entra ID app registration or any Azure credentials.
#
# How it works:
#   1. The backend sends a multipart/form-data POST to the Make webhook URL.
#   2. Make receives the metadata JSON + files and runs your scenario.
#   3. Make creates one SharePoint folder per inspection and uploads the files.
#   4. Optionally Make returns the new folder URL so the app can display a link.
#
# --- Step-by-step Make scenario setup ---
#
# Step 1 — Create a new scenario in Make (make.com → Create a new scenario)
#
# Step 2 — Add a "Webhooks > Custom Webhook" trigger module
#   a. Click "Add" next to the webhook URL field and give it a name
#      (e.g. "LCS Site Visit Upload").
#   b. Copy the generated webhook URL → paste it as MAKE_SHAREPOINT_WEBHOOK_URL below.
#   c. Run the scenario once (click the play button) and trigger a test upload
#      from the app or with curl so Make can infer the data structure.
#
# Step 3 — Add a "SharePoint > Create a Folder" module
#   a. Connect your SharePoint account (personal OAuth — no admin consent needed).
#   b. Site URL: your SharePoint site  (e.g. https://lcsprojectsolutionsltd.sharepoint.com/sites/Temporary)
#   c. Parent folder: the existing parent folder path (e.g. /Shared Documents/Site Visits)
#   d. Folder name: map from the webhook metadata:
#        {{1.metadata.suggestedFolderName}}
#      which produces names like:
#        31 - 100526 - Doswell Projects - Coldharbour Farm Road - 2026-05-10
#      (format: {ref} - {DDMMYY} - {client} - {site} - {YYYY-MM-DD})
#      Tip: you can also build the name yourself:
#        {{1.metadata.inspectionReference}} - {{1.metadata.clientName}} - {{1.metadata.siteName}} - {{1.metadata.visitDate}}
#
#   NOTE (after metadata update): click "Re-determine data structure" on the
#   Custom Webhook trigger so Make picks up the new fields (inspectionReference,
#   contractsManager, visitId, createdAt, audioSummary, photoCount, etc.).
#   The existing {{1.metadata.suggestedFolderName}} mapping is unchanged.
#
# Step 4 — Upload the audio file (if present)
#   Add "SharePoint > Upload a File" (or "Microsoft OneDrive > Upload a File")
#   a. Drive: same as above
#   b. Folder: use the folder ID returned by Step 3 ({{3.id}})
#   c. File name: {{1.audio.name}}   (Make auto-parses file metadata)
#   d. Data: {{1.audio}}
#
# Step 5 — Upload photos (use an Iterator + Router if there are multiple)
#   a. Add "Flow Control > Iterator" over {{1.photos}} (Make gives you an array)
#   b. Inside the iterator add "SharePoint > Upload a File"
#      - Folder: same folder ID from Step 3
#      - File name: {{iterator.value.name}}
#      - Data: {{iterator.value}}
#
# Step 6 — Upload visit-details.json
#   Add "SharePoint > Upload a File"
#   a. File name: visit-details.json
#   b. Data: {{1.metadata}}  (Make will serialise the JSON object)
#      Alternatively use the "Tools > Create a file from text" module with
#      {{toString(1.metadata)}} to create a proper .json file.
#
# Step 7 — (Optional) Return the folder URL to the app
#   Add a "Webhooks > Webhook Response" module at the end of the scenario.
#   Set the Response body to JSON:
#     { "folderWebUrl": "{{3.webUrl}}" }
#   (Replace 3 with the module number of the Create Folder step.)
#   The app will display a tappable "Open folder in SharePoint" link on success.
#
# Step 8 — Activate the scenario (toggle it ON in Make)
#
# Suggested folder naming (from inspection reference / site / date):
#   {{1.metadata.visitDate}} – {{1.metadata.clientName}} – {{1.metadata.siteName}}
#   Example output: 2025-07-14 – LCS Ltd – Victoria Wharf
#
# No Microsoft Entra app registration is needed.
# Authentication is handled by Make using your personal Microsoft 365 account.

# Required: paste the webhook URL from Make > Webhooks > Custom Webhook
MAKE_SHAREPOINT_WEBHOOK_URL=

# Optional: a secret string sent as the X-Make-Secret header.
# In your Make scenario you can verify this value in a Filter after the trigger
# to reject requests that didn't come from your backend.
MAKE_WEBHOOK_SECRET=

# Upload mode (default: links).
#   links  — Recommended for production. Backend stores the evidence files in
#            a temp directory and POSTs a small JSON body to the Make webhook
#            containing download URLs. Make uses its "HTTP > Get a File"
#            module to fetch each file and upload to OneDrive. Avoids the
#            "HTTP 413 Request Entity Too Large" errors that occur when audio
#            + photo zips are sent directly to Make as multipart/form-data.
#   direct — Legacy multipart/form-data upload (binaries posted to Make).
#            Retained for small local tests. Will fail with 413 on Make's
#            hosted webhook once the evidence bundle gets past a few MB.
MAKE_UPLOAD_MODE=links

# Externally-reachable base URL of THIS backend (e.g. Render).
# Used to build the download URLs in link-mode payloads, so Make's HTTP
# module can fetch <PUBLIC_BASE_URL>/api/evidence/<token>/<filename>.
# If left blank the backend derives it from the X-Forwarded-Host / Host
# header on the upload request — works fine on Render but pin the value
# here if you want stability across hosts.
PUBLIC_BASE_URL=

# How long evidence files stay accessible before being deleted from the
# server's temp directory. Default 1440 (24h) is comfortably longer than any
# Make scenario run. Drop this to 30–60 if you want a tighter exposure window.
EVIDENCE_TTL_MINUTES=1440


# ===========================================================================
# --- Microsoft Graph / SharePoint upload (LEGACY — requires Entra ID) ------
# ===========================================================================
# The Graph-based upload path is preserved and still works.
# It is only used if MAKE_SHAREPOINT_WEBHOOK_URL is blank.
# Leave all SHAREPOINT_* vars blank to disable.
# When any required var is missing, POST /api/visits/upload-sharepoint returns
# HTTP 503 with a clear error message listing what is missing.
#
# --- Azure AD app registration ---
# 1. Go to portal.azure.com → Azure Active Directory → App registrations → New.
# 2. Give the app a name (e.g. "LCS Site Visit App").
# 3. Under "Certificates & secrets" → New client secret. Copy the VALUE now
#    (it is only shown once) → SHAREPOINT_CLIENT_SECRET.
# 4. Copy the Application (client) ID → SHAREPOINT_CLIENT_ID.
# 5. Copy the Directory (tenant) ID   → SHAREPOINT_TENANT_ID.
# 6. Under "API permissions" → Add permission → Microsoft Graph → Application
#    permissions → Sites.ReadWrite.All → Add. Then click "Grant admin consent".
#
# --- Resolving the sharing link to site/drive/folder IDs ---
# The sharing URL is:
#   https://lcsprojectsolutionsltd.sharepoint.com/:f:/s/Temporary/IgDFy0CymLrRQ7WKQhNLx3FAAYRx7GxMV95kQTYBlvTEXhY?e=lH9QTS
#
#   Step A – Get an app token:
#     curl -X POST \
#       "https://login.microsoftonline.com/${SHAREPOINT_TENANT_ID}/oauth2/v2.0/token" \
#       -d "grant_type=client_credentials&client_id=${SHAREPOINT_CLIENT_ID}&client_secret=${SHAREPOINT_CLIENT_SECRET}&scope=https://graph.microsoft.com/.default"
#
#   Step B – Base64url-encode the sharing URL (Node.js one-liner):
#     node -e "
#       const url = 'https://lcsprojectsolutionsltd.sharepoint.com/:f:/s/Temporary/IgDFy0CymLrRQ7WKQhNLx3FAAYRx7GxMV95kQTYBlvTEXhY?e=lH9QTS';
#       console.log('u!' + Buffer.from(url).toString('base64').replace(/\+/g,'-').replace(/\//g,'_').replace(/=/g,''));
#     "
#
#   Step C – Resolve the link (replace <TOKEN> and <ENCODED>):
#     curl -H "Authorization: Bearer <TOKEN>" \
#       "https://graph.microsoft.com/v1.0/shares/<ENCODED>/driveItem"
#
#   From the JSON response:
#     .parentReference.siteId  → SHAREPOINT_SITE_ID
#     .parentReference.driveId → SHAREPOINT_DRIVE_ID
#     .id                      → SHAREPOINT_PARENT_FOLDER_ID

SHAREPOINT_TENANT_ID=
SHAREPOINT_CLIENT_ID=
SHAREPOINT_CLIENT_SECRET=
SHAREPOINT_SITE_ID=
SHAREPOINT_DRIVE_ID=
SHAREPOINT_PARENT_FOLDER_ID=
